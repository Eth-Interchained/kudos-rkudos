# =============================================================================
# Interchained Social Mining — environment configuration template
# Copy this file to `.env` and fill in your own credentials.
# =============================================================================

# --- Core runtime ------------------------------------------------------------
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_BASE_URL=http://localhost:3000

# --- Admin console auth (REQUIRED to use the operator console) ---------------
# SHA-256 hex hash of your admin token. Generate with:
#   node -e "console.log(require('crypto').createHash('sha256').update('YOUR_TOKEN').digest('hex'))"
ADMIN_TOKEN_SHA256=

# --- Block mining scheduler --------------------------------------------------
SCHEDULER_ENABLED=true
BLOCK_INTERVAL_MS=600000
REPLY_SYNC_INTERVAL_MS=600000
REPLY_SYNC_WINDOW=20
NETROWS_SYNC_INTERVAL_MS=120000

# --- Governance-linked reward model ------------------------------------------
GOV_REWARD_BLOCKS=10
GOV_REWARD_SHARE=0.1
ITC_GOVERNANCE_ADDRESS=itc1qg408c5vw9u4s47e5l5v5q0s0u98hprg8w94ffp
BLOCK_REWARD_FALLBACK_ITC=0.6

# --- Treasury / scoring guardrails -------------------------------------------
HOT_WALLET_BALANCE_ITC=1000
DAILY_CAP_ITC=500
AUTO_APPROVE_UNDER_ITC=50
PER_ACCOUNT_CAP_ITC=5000
QUALITY_FLOOR=60
TRUST_FLOOR=0.2
DUP_SIM_THRESHOLD=0.85

# --- ITC settlement node (Bitcoin-like JSON-RPC) -----------------------------
ITC_RPC_URL=http://
ITC_RPC_ENABLED=true
ITC_RPC_USER=
ITC_RPC_PASSWORD=
ITC_RPC_WALLET=
AUTO_BROADCAST_PAYOUTS=true

# --- NetRows (X / Twitter data source) ---------------------------------------
NETROWS_API_KEY=

# --- X / Twitter posting (optional, for write access) ------------------------
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_ACCOUNT_HANDLE=

# --- AiAS (AI reply scoring + post-content) ----------------------------------
AIAS_API_KEY=
AIAS_PROVIDER=anthropic
AIAS_MODEL=claude-haiku-4-5
AIAS_API_URL=https://api.aiassist.net

# --- Email (weekly digest blast) ---------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
